# Application
ENVIRONMENT=development
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (LLM & Whisper STT/TTS)
OPENAI_API_KEY=your_openai_api_key_here

# Twilio (Telephony)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# HubSpot (CRM)
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here

# Shopify (Commerce)
SHOPIFY_STORE_URL=https://your-shopify-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here

# Zendesk (Ticketing)
ZENDESK_SUBDOMAIN=your_zendesk_subdomain_here
ZENDESK_EMAIL=your_zendesk_email_here
ZENDESK_API_TOKEN=your_zendesk_api_token_here
