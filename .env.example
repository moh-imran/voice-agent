# Application
ENVIRONMENT=development
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (LLM & Whisper STT/TTS)
OPENAI_API_KEY=your_openai_api_key_here

# Twilio (Telephony)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Salesforce (CRM)
SALESFORCE_CLIENT_ID=your_salesforce_client_id_here
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret_here
SALESFORCE_USERNAME=your_salesforce_username_here
SALESFORCE_PASSWORD=your_salesforce_password_here
SALESFORCE_SECURITY_TOKEN=your_salesforce_security_token_here

# Magento (Commerce)
MAGENTO_BASE_URL=https://your-magento-store.com
MAGENTO_ACCESS_TOKEN=your_magento_access_token_here

# Zendesk (Ticketing)
ZENDESK_SUBDOMAIN=your_zendesk_subdomain_here
ZENDESK_EMAIL=your_zendesk_email_here
ZENDESK_API_TOKEN=your_zendesk_api_token_here
